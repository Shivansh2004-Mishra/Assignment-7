<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Todo list</title>
    <link rel="stylesheet" href="CSS/list.css">
</head>
<body>
     <header class="box">
        <h1>Todo List</h1>
    </header>
    
    <div class="box">

        <% ejes.forEach(function(items){ %>
            <form action="/delete" method="post">
                <div class="item">
                    <input  type="checkbox" name="checkbox1" value="<%= items._id %>" onchange="this.form.submit()">
                    <p> <%= items.name %>
                </div>
            </form>
        <% }) %>
        
    
    <form action="/" method="Post">
        <input type="text" name="ele1" placeholder="Enter the task">
        <button type="submit"><ion-icon class="pen" name="pencil"></ion-icon></button>
    </form>
    </div>
    <footer class="footer" style="margin-top: 2em; text-align: center; color: #888;">
        <p>&copy; <%= new Date().getFullYear() %> Todo List App</p>
    </footer>
    <script type="module" src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.esm.js"></script>
<script nomodule src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.js"></script>
</body>
</html>